{
  "name": "@omnitwin/types",
  "version": "0.0.1",
  "private": true,
  "description": "Shared TypeScript interfaces, Zod schemas, and enums for the OMNITWIN platform",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "@eslint/js": "^9.19.0",
    "typescript-eslint": "^8.22.0",
    "eslint": "^9.19.0"
  }
}
