# =============================================================================
# OMNITWIN Web — production environment template
# =============================================================================
# Copy each VITE_* KEY=value line into Vercel's Environment Variables panel
# (Project Settings → Environment Variables → add each for "Production").
#
# All VITE_* vars are BUNDLED INTO THE CLIENT BUNDLE — they are publicly
# visible once the site is deployed. Only put public / publishable keys
# here. Never put a secret key (sk_live_*, server-only token, etc).
# =============================================================================

# API base URL — the Railway production URL behind your api.<domain> CNAME
VITE_API_URL=https://api.venviewer.com

# Clerk publishable key (pk_live_... for production)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_

# Sentry DSN for the web app (optional — frontend error tracking)
VITE_SENTRY_DSN=https://<key>@o<org-id>.ingest.sentry.io/<web-project-id>

# PostHog (optional — product analytics)
VITE_POSTHOG_KEY=phc_
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Stripe publishable key for client-side payment flows
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_
