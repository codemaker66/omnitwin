# =============================================================================
# OMNITWIN API — environment variables
# =============================================================================
# Copy this file to `.env` and fill in real values for local development.
# In production all values come from the deployment environment (Railway,
# Fly.io, etc) — never commit a real .env file.
#
# Validation: src/env.ts uses Zod to validate every variable at startup.
# The server refuses to boot if validation fails. In NODE_ENV=production,
# CLERK_SECRET_KEY and CLERK_WEBHOOK_SECRET are HARD-REQUIRED.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Environment mode. One of: development | test | production
# In `production`, additional vars become required (Clerk secret + webhook).
NODE_ENV=development

# HTTP port the Fastify server listens on. Default 3001.
PORT=3001


# -----------------------------------------------------------------------------
# Database — Neon serverless PostgreSQL
# -----------------------------------------------------------------------------

# Full Postgres connection string with sslmode=require. Get this from the
# Neon dashboard for your project.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require


# -----------------------------------------------------------------------------
# Clerk — authentication provider (https://dashboard.clerk.com)
# -----------------------------------------------------------------------------

# Publishable key (pk_test_... in dev, pk_live_... in prod). Safe to expose
# to the frontend; the web package also reads its own VITE_CLERK_PUBLISHABLE_KEY.
CLERK_PUBLISHABLE_KEY=pk_test_your-key-here

# Secret key (sk_test_... in dev, sk_live_... in prod). NEVER commit.
# REQUIRED in production — the server refuses to boot without it.
CLERK_SECRET_KEY=sk_test_your-secret-here

# Webhook signing secret from the Clerk dashboard's webhook endpoint config
# (Webhooks → your endpoint → Signing Secret). Used to verify Svix-signed
# `user.created`, `user.updated`, `user.deleted` events.
#
# REQUIRED in production. Without this, the webhook handler would silently
# accept unsigned events from any attacker — startup validation refuses
# to let production boot in that state.
CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret


# -----------------------------------------------------------------------------
# CORS — allowed origins for browser requests
# -----------------------------------------------------------------------------

# Comma-separated list, no spaces. The web frontend's deployment URL must
# be in here in production (e.g. https://omnitwin.vercel.app).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174


# -----------------------------------------------------------------------------
# Email — Resend (https://resend.com)
# -----------------------------------------------------------------------------

# OPTIONAL. If unset, email-sending services log to console instead of
# delivering — useful for dev. Production should always set this.
RESEND_API_KEY=re_your-resend-api-key

# From address for outbound email. Must be a verified domain in Resend.
EMAIL_FROM=OMNITWIN <notifications@omnitwin.com>


# -----------------------------------------------------------------------------
# File uploads — Cloudflare R2 (S3-compatible)
# -----------------------------------------------------------------------------

# OPTIONAL group. If any are unset, the /uploads/presigned route returns
# a clean error and the upload UI is hidden. All four must be set together
# in any environment that needs file uploads.
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=omnitwin-uploads

# Public URL prefix for served files. Configure your R2 bucket with a
# custom domain or use the r2.dev URL.
R2_PUBLIC_URL=https://uploads.example.com
