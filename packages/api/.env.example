# Database — Neon serverless PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT — secret for signing access tokens (min 32 chars)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Server port (default 3001)
PORT=3001

# Clerk — authentication provider
CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-secret-here

# Resend — email notifications (optional — logs to console if not set)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=OMNITWIN <notifications@omnitwin.com>
