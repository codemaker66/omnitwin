# =============================================================================
# VenViewer API — production environment template
# =============================================================================
# Copy each KEY=value line into Railway's Variables panel for the api service.
# Every variable here is REQUIRED unless marked (optional).
#
# Source of truth for validation: packages/api/src/env.ts (Zod schema).
# The server refuses to boot if any required variable is missing or empty.
# =============================================================================

# Runtime
NODE_ENV=production
PORT=3001

# Commit provenance — set by Railway / CI so /health/version can surface them.
# Railway auto-injects RAILWAY_GIT_COMMIT_SHA; alias it in Railway via a
# variable reference, e.g. GIT_SHA=${{RAILWAY_GIT_COMMIT_SHA}}
GIT_SHA=
BUILD_TIMESTAMP=

# Database — Neon production pooled connection string
# Get this from Neon console → your project → Branches → production → pooled connection.
# Must include sslmode=require. channel_binding=require is recommended.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require&channel_binding=require

# JWT signing secret — generate fresh for production: `openssl rand -hex 32`
JWT_SECRET=<generate-new-32-byte-hex>

# Clerk — production workspace keys (pk_live_..., sk_live_..., whsec_...)
CLERK_PUBLISHABLE_KEY=pk_live_
CLERK_SECRET_KEY=sk_live_
CLERK_WEBHOOK_SECRET=whsec_

# CORS — production web origins (comma-separated, no spaces, no trailing slash)
CORS_ORIGINS=https://venviewer.com,https://www.venviewer.com

# Email — Resend production API key + verified sender address on your domain
RESEND_API_KEY=re_
EMAIL_FROM=VenViewer <notifications@venviewer.com>

# Cloudflare R2 — production bucket with custom public domain
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=venviewer-prod
R2_PUBLIC_URL=https://uploads.venviewer.com

# Frontend URL — used in outbound email links
FRONTEND_URL=https://venviewer.com

# Sentry — error tracking (optional but strongly recommended in prod)
SENTRY_DSN=https://<key>@o<org-id>.ingest.sentry.io/<project-id>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus scrape token — 16+ chars. /metrics returns 404 when unset.
# Generate: `openssl rand -hex 16`
METRICS_TOKEN=<generate-16-byte-hex>

# Stripe — billing (optional until you're charging customers)
STRIPE_SECRET_KEY=sk_live_
STRIPE_PUBLISHABLE_KEY=pk_live_
STRIPE_WEBHOOK_SECRET=whsec_
