{
  "name": "@omnitwin/api",
  "version": "0.0.3",
  "private": true,
  "description": "OMNITWIN API — Fastify + Drizzle ORM + Neon PostgreSQL",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit",
    "test": "vitest run --exclude src/__tests__/integration.test.ts",
    "test:integration": "vitest run src/__tests__/integration.test.ts",
    "test:watch": "vitest watch --exclude src/__tests__/integration.test.ts",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "cleanup": "tsx src/scripts/run-cleanup.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "email:dev": "email dev --dir ./emails --port 3002",
    "email:export": "email export --dir ./emails --outDir ./emails-out"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@clerk/backend": "^3.2.2",
    "@clerk/fastify": "^3.1.4",
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/websocket": "^11.2.0",
    "@neondatabase/serverless": "^0.10.4",
    "@omnitwin/types": "workspace:*",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sentry/node": "^8",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "fastify-raw-body": "^5.0.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.9.4",
    "svix": "^1.89.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.19.0",
    "pino-pretty": "^13.1.3",
    "react-email": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vitest": "^3.0.5"
  }
}
