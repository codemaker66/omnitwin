{
  "name": "omnitwin",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Browser-based venue planning platform",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "postinstall": "node ./packages/types/node_modules/typescript/bin/tsc --project packages/types/tsconfig.build.json"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@<2": "1.1.13",
      "brace-expansion@>=4 <5.0.6": "5.0.6",
      "esbuild": "0.25.0",
      "fast-uri": "3.1.2",
      "fast-xml-builder": "1.1.7",
      "flatted": "3.4.2",
      "js-cookie@<=3.0.5": "3.0.7",
      "picomatch": "4.0.4",
      "postcss": "8.5.10",
      "resend>svix": "1.92.2",
      "js-yaml@<=4.1.1": "4.2.0",
      "shell-quote@>=1.1.0 <=1.8.3": "1.8.4",
      "vite": "6.4.3",
      "ws@>=8.0.0 <8.21.0": "8.21.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "9.19.0",
    "typescript-eslint": "8.22.0"
  }
}
