{
  "name": "omnitwin",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Browser-based photorealistic venue planning platform",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "postinstall": "pnpm --filter @omnitwin/types build"
  }
}
