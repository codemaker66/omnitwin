{
  "name": "omnitwin",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Browser-based photorealistic venue planning platform",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "postinstall": "pnpm --filter @omnitwin/types build"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@<2": "1.1.13",
      "brace-expansion@>=4 <5.0.5": "5.0.5",
      "esbuild": "0.25.0",
      "flatted": "3.4.2",
      "picomatch": "4.0.4",
      "postcss": "8.5.10",
      "resend>svix": "1.92.2",
      "vite": "6.4.2"
    }
  }
}
